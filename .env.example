# Server Configuration
PORT=5000

# Redis Configuration (Make sure Redis is installed and running)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# SMTP Configuration (Example: Gmail, SendGrid, Amazon SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# AI Orchestrator URL
AI_ORCHESTRATOR_URL=http://localhost:4000/api/orchestrate

# Meta API Configuration for Social Scheduler
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
IG_USER_ID=
IG_ACCESS_TOKEN=
PUBLIC_BASE_URL=https://your-public-url.com
